# server/.env.example
# PHASE 2 UPDATED: Complete environment configuration

# ────────────────────────────────────────────────────────────────────────────
# REQUIRED API KEYS
# ────────────────────────────────────────────────────────────────────────────

# Google Gemini API Key (for simple/medium complexity cases)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="AIzaSyAvucp4Lsbo4k5YFbGuODyKdVqlY8KWVig"
# Anthropic Claude API Key (for complex cases & fallback)
# Get from: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-your-claude-api-key-here

# ────────────────────────────────────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://ravikolliai_db_user:PrNUxATYsAJaB2hc@niti-setu.hnbcnzq.mongodb.net/?appName=niti-setu"

# ────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────

# Server port (default: 5000)
PORT=5000

# Production origin for CORS (set for production deployment)
# PROD_ORIGIN=https://niti-setu.vercel.app

# ────────────────────────────────────────────────────────────────────────────
# PHASE 2: OPTIMIZATION CONFIGURATION
# ────────────────────────────────────────────────────────────────────────────

# LLM Model Selection
# Options: 'gemini' (fast, cheap), 'claude' (accurate, slower)
# Default: auto-select based on complexity
LLM_PRIMARY_MODEL=gemini
LLM_FALLBACK_MODEL=claude

# Context Caching
# Enable context caching to reduce token usage (default: true)
ENABLE_CONTEXT_CACHE=true

# Cache TTL in hours (default: 24)
CONTEXT_CACHE_TTL_HOURS=24

# Complexity Score Threshold
# If score > this value, use Claude instead of Gemini (default: 3)
COMPLEXITY_THRESHOLD=3

# Reduce chunk retrieval for token optimization
# Default: 3 (reduced from original 5-6)
MAX_CHUNKS_TO_RETRIEVE=3

# ────────────────────────────────────────────────────────────────────────────
# MONITORING & LOGGING
# ────────────────────────────────────────────────────────────────────────────

# Log level: 'debug', 'info', 'warn', 'error' (default: 'info')
LOG_LEVEL=info

# Enable performance metrics tracking (default: true)
ENABLE_METRICS=true

# Metrics collection interval in milliseconds
METRICS_INTERVAL=60000

# ────────────────────────────────────────────────────────────────────────────
# FEATURES (Phase 2)
# ────────────────────────────────────────────────────────────────────────────

# Enable rule-based filtering (default: true)
ENABLE_RULE_BASED_FILTERING=true

# Enable model auto-selection (default: true)
ENABLE_MODEL_AUTO_SELECTION=true

# Enable fallback to alternative model (default: true)
ENABLE_MODEL_FALLBACK=true

# Enable multilingual support (Phase 2)
ENABLE_MULTILINGUAL=true

# ────────────────────────────────────────────────────────────────────────────
# NOTES
# ────────────────────────────────────────────────────────────────────────────
# 1. Keep this file secure - never commit to version control
# 2. Use .env.local for local development (not committed)
# 3. Set proper values in deployment environments
# 4. For production, use secret management (AWS Secrets, GitHub Secrets, etc.)
